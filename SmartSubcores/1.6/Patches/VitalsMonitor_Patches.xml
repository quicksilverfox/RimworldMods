<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- 
		Vitals Monitor Integration
		Adds subcore automation to Vitals Monitor for enhanced surgery success.
		With High subcore installed, provides the missing 2% success chance for skilled surgeons,
		ensuring they never catastrophically fail surgery (98% cap -> 100% guaranteed).
	-->

	<!-- Vitals Monitor -->
	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/ThingDef[defName="VitalsMonitor"]/comps</xpath>
		<match Class="PatchOperationAdd">
			<xpath>/Defs/ThingDef[defName="VitalsMonitor"]/comps</xpath>
			<value>
				<li Class="SubcoreAutomation.Core.CompProperties_UtilityAutomation">
					<tier>High</tier>
					<automatedSpeedFactor>0</automatedSpeedFactor>
					<automatedPowerConsumption>0</automatedPowerConsumption>
					<installWorkAmount>2500</installWorkAmount>
				</li>
			</value>
		</match>
	</Operation>

</Patch>
