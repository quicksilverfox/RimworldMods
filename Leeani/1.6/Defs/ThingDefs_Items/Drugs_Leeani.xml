<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--=========================== Leeani Soul Wine ==============================-->

	<ThingDef ParentName="DrugBase">
		<defName>LeeaniSoulWine</defName>
		<label>soul wine</label>
		<description>A traditional Leeani wine brewed from specially cultivated grapes. The unique fermentation process creates a psychically-attuned beverage that enhances neural sensitivity, improving psycasting abilities. Like all alcohol, it can be addictive.\n\nThis ancient drink has been central to Leeani culture for millennia, often consumed during meditation and spiritual ceremonies.</description>
		<graphicData>
			<texPath>Things/Item/Drug/Beer</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<equippedAngleOffset>-150</equippedAngleOffset>
		<rotatable>false</rotatable>
		<stackLimit>25</stackLimit>
		<statBases>
			<DeteriorationRate>0.5</DeteriorationRate>
			<MarketValue>26</MarketValue>
			<Mass>0.3</Mass>
			<Flammability>0.5</Flammability>
			<Nutrition>0.08</Nutrition>
		</statBases>
		<ingestible>
			<foodType>Fluid, Processed, Liquor</foodType>
			<joyKind>Chemical</joyKind>
			<joy>0.17</joy>
			<nurseable>true</nurseable>
			<drugCategory>Social</drugCategory>
			<ingestSound>Ingest_Beer</ingestSound>
			<ingestHoldOffsetStanding>
				<northDefault>
					<offset>(0.18,0,0)</offset>
				</northDefault>
			</ingestHoldOffsetStanding>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Drink {0}</ingestCommandString>
			<ingestReportString>Drinking {0}.</ingestReportString>
			<chairSearchRadius>25</chairSearchRadius>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholHigh</hediffDef>
					<severity>0.15</severity>
					<toleranceChemical>Alcohol</toleranceChemical>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff" MayRequire="Ludeon.RimWorld.Royalty">
					<hediffDef>LeeaniSoulWineHigh</hediffDef>
					<severity>0.50</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		<equipmentType>Primary</equipmentType>
		<techLevel>Neolithic</techLevel>
		<comps>
			<li Class="CompProperties_Drug">
				<chemical>Alcohol</chemical>
				<addictiveness>0.010</addictiveness>
				<minToleranceToAddict>0.25</minToleranceToAddict>
				<existingAddictionSeverityOffset>0.20</existingAddictionSeverityOffset>
				<needLevelOffset>1</needLevelOffset>
				<listOrder>10</listOrder>
			</li>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>14</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<tools>
			<li>
				<label>bottle</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>neck</label>
				<capacities>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<tradeTags>
			<li>LeeaniDrug</li>
		</tradeTags>
	</ThingDef>

	<!--=========================== Soul Wine Psycasting Hediff ==============================-->

	<HediffDef MayRequire="Ludeon.RimWorld.Royalty">
		<defName>LeeaniSoulWineHigh</defName>
		<label>soul wine (psychic)</label>
		<description>Psychic enhancement from Leeani soul wine. Neural sensitivity is heightened, improving psycasting abilities.</description>
		<hediffClass>Hediff_High</hediffClass>
		<defaultLabelColor>(1,0,0.5)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-1.5</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<PsychicSensitivity>0.15</PsychicSensitivity>
					<MeditationFocusGain>0.10</MeditationFocusGain>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

	<!--=========================== Leeani Spirit (Distilled) ==============================-->

	<ThingDef ParentName="DrugBase">
		<defName>LeeaniSoulSpirit</defName>
		<label>soul spirit</label>
		<description>A highly concentrated distillation of Leeani soul wine. This potent psychically-attuned spirit has extremely high alcohol content - dangerously intoxicating for most species. The Leeani, with their alcohol-impervious genes, can consume it safely to experience intense psychic enhancement.\n\nLike flake versus psychite tea, this represents a more intense and dangerous alternative to traditional soul wine.</description>
		<graphicData>
			<texPath>Things/Item/Drug/Beer</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<color>(200,160,200)</color>
		</graphicData>
		<equippedAngleOffset>-150</equippedAngleOffset>
		<rotatable>false</rotatable>
		<stackLimit>25</stackLimit>
		<statBases>
			<DeteriorationRate>0.5</DeteriorationRate>
			<MarketValue>45</MarketValue>
			<Mass>0.2</Mass>
			<Flammability>1.0</Flammability>
			<Nutrition>0.02</Nutrition>
		</statBases>
		<ingestible>
			<foodType>Fluid, Processed, Liquor</foodType>
			<joyKind>Chemical</joyKind>
			<joy>0.25</joy>
			<nurseable>true</nurseable>
			<drugCategory>Hard</drugCategory>
			<ingestSound>Ingest_Beer</ingestSound>
			<ingestHoldOffsetStanding>
				<northDefault>
					<offset>(0.18,0,0)</offset>
				</northDefault>
			</ingestHoldOffsetStanding>
			<ingestHoldUsesTable>false</ingestHoldUsesTable>
			<ingestCommandString>Drink {0}</ingestCommandString>
			<ingestReportString>Drinking {0}.</ingestReportString>
			<chairSearchRadius>25</chairSearchRadius>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholHigh</hediffDef>
					<severity>0.45</severity>
					<toleranceChemical>Alcohol</toleranceChemical>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>AlcoholTolerance</hediffDef>
					<severity>0.050</severity>
					<divideByBodySize>true</divideByBodySize>
					<multiplyByGeneToleranceFactors>true</multiplyByGeneToleranceFactors>
				</li>
				<li Class="IngestionOutcomeDoer_GiveHediff" MayRequire="Ludeon.RimWorld.Royalty">
					<hediffDef>LeeaniSoulSpiritHigh</hediffDef>
					<severity>1.0</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		<equipmentType>Primary</equipmentType>
		<techLevel>Industrial</techLevel>
		<comps>
			<li Class="CompProperties_Drug">
				<chemical>Alcohol</chemical>
				<addictiveness>0.015</addictiveness>
				<minToleranceToAddict>0.20</minToleranceToAddict>
				<existingAddictionSeverityOffset>0.25</existingAddictionSeverityOffset>
				<needLevelOffset>1</needLevelOffset>
				<listOrder>11</listOrder>
			</li>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>30</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<tools>
			<li>
				<label>bottle</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>neck</label>
				<capacities>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
		<tradeTags>
			<li>LeeaniDrug</li>
		</tradeTags>
	</ThingDef>

	<!--=========================== Soul Spirit Psycasting Hediff ==============================-->

	<HediffDef MayRequire="Ludeon.RimWorld.Royalty">
		<defName>LeeaniSoulSpiritHigh</defName>
		<label>soul spirit (psychic)</label>
		<description>Intense psychic enhancement from distilled soul spirit. Neural sensitivity is dramatically heightened, greatly improving psycasting abilities. The concentrated nature makes this effect much stronger than regular soul wine.</description>
		<hediffClass>Hediff_High</hediffClass>
		<defaultLabelColor>(1,0,0.5)</defaultLabelColor>
		<scenarioCanAdd>true</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-2.0</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
		</comps>
		<stages>
			<li>
				<statOffsets>
					<PsychicSensitivity>0.30</PsychicSensitivity>
					<MeditationFocusGain>0.20</MeditationFocusGain>
				</statOffsets>
			</li>
		</stages>
	</HediffDef>

</Defs>
