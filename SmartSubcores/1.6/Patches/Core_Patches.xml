<?xml version="1.0" encoding="utf-8"?>
<Patch>
	<!-- Hi-Tech Research Bench: Add tickerType -->
	<Operation Class="PatchOperationConditional">
		<xpath>/Defs/ThingDef[defName="HiTechResearchBench"]/tickerType</xpath>
		<nomatch Class="PatchOperationAdd">
			<xpath>/Defs/ThingDef[defName="HiTechResearchBench"]</xpath>
			<value>
				<tickerType>Normal</tickerType>
			</value>
		</nomatch>
	</Operation>

	<!-- Hi-Tech Research Bench: Add automation comp -->
	<!-- Speed factor 0.55 = ~150 research/day. Only one bench works at a time by default. -->
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/ThingDef[defName="HiTechResearchBench"]/comps</xpath>
		<value>
			<li Class="SubcoreAutomation.Core.CompProperties_MiscAutomation">
				<subcoreDef>SubcoreHigh</subcoreDef>
				<automatedSpeedFactor>0.55</automatedSpeedFactor>
				<automatedPowerConsumption>500</automatedPowerConsumption>
				<installWorkAmount>4000</installWorkAmount>
			</li>
		</value>
	</Operation>

