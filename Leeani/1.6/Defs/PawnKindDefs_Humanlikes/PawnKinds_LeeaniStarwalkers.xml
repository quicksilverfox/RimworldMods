<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!-- Base PawnKind for all Starwalkers -->
	<PawnKindDef Name="LeeaniStarwalkerBase" Abstract="True">
		<race>Human</race>
		<xenotypeSet>
			<xenotypeChances>
				<Leeani>1</Leeani>
			</xenotypeChances>
		</xenotypeSet>
		<defaultFactionType>LeeaniStarwalkers</defaultFactionType>
		<chemicalAddictionChance>0.02</chemicalAddictionChance>
		<apparelAllowHeadgearChance>0.5</apparelAllowHeadgearChance>
		<backstoryCryptosleepCommonality>0.3</backstoryCryptosleepCommonality>
		<invNutrition>2.55</invNutrition>
		<apparelTags>
			<li>IndustrialBasic</li>
			<li>IndustrialAdvanced</li>
			<li>IndustrialMilitaryBasic</li>
			<li>IndustrialMilitaryAdvanced</li>
			<li>SpacerMilitary</li>
		</apparelTags>
		<initialWillRange>2~5</initialWillRange>
		<initialResistanceRange>10~18</initialResistanceRange>
	</PawnKindDef>

	<!-- Civilian / Peaceful -->
	<PawnKindDef ParentName="LeeaniStarwalkerBase">
		<defName>LeeaniStarwalker_Citizen</defName>
		<label>starwalker citizen</label>
		<combatPower>50</combatPower>
		<isFighter>false</isFighter>
		<gearHealthRange>1~1</gearHealthRange>
		<itemQuality>Normal</itemQuality>
		<backstoryCategories>
			<li>Offworld</li>
		</backstoryCategories>
		<weaponTags>
			<li>SimpleGun</li>
			<li>Gun</li>
		</weaponTags>
		<weaponMoney>300~800</weaponMoney>
		<apparelMoney>800~1500</apparelMoney>
		<techHediffsChance>0.15</techHediffsChance>
		<techHediffsMoney>500~1200</techHediffsMoney>
		<techHediffsTags>
			<li>Normal</li>
			<li>Simple</li>
			<li>Advanced</li>
			<li>ImplantEmpireCommon</li>
		</techHediffsTags>
		<inventoryOptions>
			<skipChance>0.7</skipChance>
			<subOptionsChooseOne>
				<li>
					<choiceChance>90</choiceChance>
					<thingDef>Silver</thingDef>
					<countRange>
						<min>50</min>
						<max>150</max>
					</countRange>
				</li>
				<li>
					<choiceChance>10</choiceChance>
					<thingDef>Silver</thingDef>
					<countRange>
						<min>800</min>
						<max>1500</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>

	<!-- Basic combat unit -->
	<PawnKindDef ParentName="LeeaniStarwalkerBase">
		<defName>LeeaniStarwalker_Soldier</defName>
		<label>starwalker soldier</label>
		<combatPower>100</combatPower>
		<isFighter>true</isFighter>
		<gearHealthRange>0.7~2.0</gearHealthRange>
		<itemQuality>Normal</itemQuality>
		<backstoryCategories>
			<li>Offworld</li>
		</backstoryCategories>
		<apparelMoney>1000~2000</apparelMoney>
		<weaponMoney>800~1800</weaponMoney>
		<weaponTags>
			<li>Gun</li>
			<li>IndustrialGunAdvanced</li>
		</weaponTags>
		<techHediffsChance>0.20</techHediffsChance>
		<techHediffsMoney>800~2000</techHediffsMoney>
		<techHediffsTags>
			<li>Normal</li>
			<li>Simple</li>
			<li>Advanced</li>
			<li>ImplantEmpireCommon</li>
		</techHediffsTags>
		<inventoryOptions>
			<skipChance>0.75</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>Silver</thingDef>
					<countRange>
						<min>200</min>
						<max>500</max>
					</countRange>
				</li>
				<li>
					<thingDef>MedicineIndustrial</thingDef>
					<countRange>
						<min>1</min>
						<max>3</max>
					</countRange>
				</li>
			</subOptionsChooseOne>
		</inventoryOptions>
	</PawnKindDef>

	<!-- Elite combat unit -->
