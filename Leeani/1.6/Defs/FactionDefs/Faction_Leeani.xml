<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<FactionDef ParentName="FactionBase">
		<defName>LeeaniHold</defName>
		<label>Leeani hold</label>
		<description>A hold of the mysterious Leeani race.</description>
		<pawnSingular>Leeani</pawnSingular>
		<pawnsPlural>Leeani</pawnsPlural>
		<listOrderPriority>30</listOrderPriority>
		<settlementGenerationWeight>0.55</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>31</configurationListOrderPriority>	
		<canMakeRandomly>true</canMakeRandomly>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<leaderTitle>Loord</leaderTitle>		
		<factionNameMaker>NamerFactionOutlander</factionNameMaker>
		<settlementNameMaker>NamerSettlementOutlander</settlementNameMaker>
		<techLevel>Medieval</techLevel>
		<allowedCultures><li>Rustican</li><li>Corunan</li></allowedCultures>

		<!-- Ideology preferences -->
		<styles MayRequire="Ludeon.RimWorld.Ideology">
			<li>Rustic</li>
			<li>Morbid</li>
		</styles>

		<!-- Structure meme weights - never theistic, prefer spiritual/archist -->
		<structureMemeWeights MayRequire="Ludeon.RimWorld.Ideology">
			<Structure_TheistEmbodied>0</Structure_TheistEmbodied>
			<Structure_TheistAbstract>0</Structure_TheistAbstract>
			<Structure_Ideological>1</Structure_Ideological>
			<Structure_Archist>3</Structure_Archist>
		</structureMemeWeights>

		<!-- Disallowed memes - never body purists, never certain extremes -->
		<disallowedMemes MayRequire="Ludeon.RimWorld.Ideology">
			<li>BodyPurist</li>
			<li>Blindsight</li>
			<li>Tunneler</li>
			<li>Darkness</li>
			<li>TreeConnection</li>
			<li>Raider</li>
			<li>Nudism</li>
			<li>PainIsVirtue</li>
			<li>Guilt</li>
		</disallowedMemes>

		<!-- All Traditionalists are Leeani xenotype -->
		<xenotypeSet>
			<xenotypeChances>
				<Leeani>1</Leeani>
			</xenotypeChances>
		</xenotypeSet>

		<!-- VPE Psycaster paths - prefer peaceful/defensive paths -->
		<psychicPathsWeights MayRequire="VanillaExpanded.VPsycastsE">
			<VPE_Wildspeaker>3</VPE_Wildspeaker>
			<VPE_Empath>3</VPE_Empath>
			<VPE_Harmonist>3</VPE_Harmonist>
			<VPE_Protector>3</VPE_Protector>
			<VPE_Necropath>2</VPE_Necropath>
			<VPE_Frostshaper>2</VPE_Frostshaper>
			<!-- Less likely but possible -->
			<VPE_Skipmaster>1</VPE_Skipmaster>
			<VPE_Chronopath>1</VPE_Chronopath>
			<!-- Avoid aggressive paths -->
			<VPE_Warlord>0</VPE_Warlord>
			<VPE_Conflagrator>0</VPE_Conflagrator>
		</psychicPathsWeights>

	 <backstoryFilters>
      <li>
        <categories>
          <li>Outlander</li>
        </categories>
        <commonality>0.05</commonality>
      </li>
      <li>
        <categories>
          <li>Offworld</li>
        </categories>
        <commonality>0.05</commonality>
      </li>
	<li>
        <categories>
          <li>LeeaniBackstory</li>
        </categories>
        <commonality>0.90</commonality>
      </li>
    </backstoryFilters>				
		<visitorTraderKinds>
			<li>Visitor_Outlander_Standard</li>
		</visitorTraderKinds>
		<caravanTraderKinds>
			<li>Caravan_Leeani_BulkGoods</li>
			<li>Caravan_Leeani_CombatSupplier</li>
			<li>Caravan_Leeani_Exotic</li>
		</caravanTraderKinds>
		<baseTraderKinds>
			<li>Base_Leeani_Standard</li>
		</baseTraderKinds>
		<allowedArrivalTemperatureRange>
			<min>-50</min>
			<max>40</max>
		</allowedArrivalTemperatureRange>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0,35)</li>
				<li>(70, 50)</li>
				<li>(700, 100)</li>
				<li>(1300, 150)</li>
				<li>(100000, 10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<raidCommonalityFromPointsCurve>
      <points>
        <li>(0, 1)</li>
      </points>
    </raidCommonalityFromPointsCurve>
<raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
		<pawnGroupMakers>
			<li>
				<kindDef>Combat</kindDef>
				<commonality>100</commonality>
				<options>
					<LeeaniTradie>5</LeeaniTradie>
					<LeeaniSoldier>10</LeeaniSoldier>
					<LeeaniScout>5</LeeaniScout>
					<LeeaniMercenary>10</LeeaniMercenary>
					<LeeaniCaptain>5</LeeaniCaptain>
					<LeeaniChampion>5</LeeaniChampion>
					<LeeaniLoord>1</LeeaniLoord>
				</options>
			</li>
			<li>
				<kindDef>Peaceful</kindDef>
				<commonality>100</commonality>
				<options>
					<LeeaniTradie>10</LeeaniTradie>
					<LeeaniSoldier>7</LeeaniSoldier>
					<LeeaniScout>1</LeeaniScout>
					<LeeaniCaptain>1</LeeaniCaptain>
					<LeeaniChampion>1</LeeaniChampion>
					<LeeaniLoord>10</LeeaniLoord>
				</options>
			</li>
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<LeeaniTrader>1</LeeaniTrader>
				</traders>
				<carriers>
					<Muffalo>2</Muffalo>
					<Dromedary>2</Dromedary>
				</carriers>
				<guards>
					<LeeaniSoldier>10</LeeaniSoldier>
					<LeeaniScout>10</LeeaniScout>
					<LeeaniCaptain>5</LeeaniCaptain>
					<LeeaniChampion>5</LeeaniChampion>
					<LeeaniLoord>5</LeeaniLoord>
				</guards>
			</li>
			<li>
				<kindDef>Settlement</kindDef>			
				<options>
					<LeeaniTradie>10</LeeaniTradie>
					<LeeaniSoldier>10</LeeaniSoldier>
					<LeeaniScout>10</LeeaniScout>
					<LeeaniMercenary>10</LeeaniMercenary>
					<LeeaniCaptain>5</LeeaniCaptain>
					<LeeaniChampion>5</LeeaniChampion>
					<LeeaniLoord>5</LeeaniLoord>	
				</options>
			</li>
		</pawnGroupMakers>
		<factionIconPath>World/LeeaniBaseIcon</factionIconPath>
		<settlementTexturePath>World/LeeaniBaseIcon</settlementTexturePath>
		<colorSpectrum>
			<li>(172, 104, 0)</li>
			<li>(69, 51, 0)</li>
		</colorSpectrum>

		<!-- Shared goodwill with Starwalkers - cultural bonds -->
		<goodwillDynamic>
			<li>
				<otherFactionDef>LeeaniStarwalkers</otherFactionDef>
				<naturalGoodwillRange>70~100</naturalGoodwillRange>
				<canBecomeHostile>false</canBecomeHostile>
			</li>
		</goodwillDynamic>
	</FactionDef>

</Defs>