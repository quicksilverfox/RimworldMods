<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Joy kind for animal interaction -->
  <JoyKindDef>
    <defName>AL_AnimalInteraction</defName>
    <label>animal interaction</label>
    <description>Playing with and interacting with animals.</description>
  </JoyKindDef>

  <!-- Joy giver for playing with animals -->
  <JoyGiverDef>
    <defName>AL_PlayWithAnimal</defName>
    <giverClass>AnimalsLogic.Recreation.JoyGiver_PlayWithAnimal</giverClass>
    <baseChance>2</baseChance>
    <joyKind>AL_AnimalInteraction</joyKind>
    <requiredCapacities>
      <li>Moving</li>
      <li>Manipulation</li>
    </requiredCapacities>
    <jobDef>AL_PlayWithAnimal</jobDef>
    <pctPawnsEverDo>0.7</pctPawnsEverDo>
    <canDoWhileInBed>false</canDoWhileInBed>
  </JoyGiverDef>

</Defs>
