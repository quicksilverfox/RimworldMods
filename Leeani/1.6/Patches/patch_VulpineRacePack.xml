<?xml version="1.0" encoding="UTF-8"?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>EPOE Vulpine Race Pack Patch</li>
		</mods>

		<match Class="PatchOperationSequence">
			<success>Always</success>
			<operations>
				<!-- Leeani are now Human xenotypes, so surgeries apply to Human race by default -->
				<!-- Just need to ensure the tail bodypart is supported for cross-compatibility -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/RecipeDef[defName='InstallVulpTail' or defName='InstallFBionicTail']/appliedOnFixedBodyParts</xpath>
					<value>
						<li>LeeaniTail</li>
					</value>
				</li>
				<!-- Allow vulpine races to use Leeani tail implants if they exist -->
				<li Class="PatchOperationAdd">
					<xpath>Defs/RecipeDef[defName='InstallLeeaniTail' or defName='InstallBionicLeeaniTail']/recipeUsers</xpath>
					<value>
						<li>Alien_Fennex</li>
						<li>Alien_Frijjid</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>