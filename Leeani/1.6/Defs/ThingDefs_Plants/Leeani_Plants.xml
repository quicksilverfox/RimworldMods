<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--=========================== Leeani Grape Vine ==============================-->

	<ThingDef ParentName="PlantBase">
		<defName>PlantLeeaniGrape</defName>
		<label>grape vine</label>
		<description>A cultivated vine that produces plump grapes. Used to make the traditional Leeani soul wine, a psychically-attuned beverage. The grapes are also tasty when eaten raw.</description>
		<statBases>
			<Nutrition>0.35</Nutrition>
			<MaxHitPoints>85</MaxHitPoints>
		</statBases>
		<graphicData>
			<texPath>Things/Plant/GrapeVine</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>(3.0,3.0)</drawSize>
		</graphicData>
		<selectable>true</selectable>
		<pathCost>10</pathCost>
		<plant>
			<fertilitySensitivity>0.6</fertilitySensitivity>
			<growDays>10.0</growDays>
			<dieIfLeafless>true</dieIfLeafless>
			<harvestTag>Standard</harvestTag>
			<harvestedThingDef>RawGrapes</harvestedThingDef>
			<harvestYield>10</harvestYield>
			<sowMinSkill>6</sowMinSkill>
			<sowTags>
				<li>Ground</li>
				<li>Hydroponic</li>
			</sowTags>
			<sowResearchPrerequisites>
				<li>TreeSowing</li>
			</sowResearchPrerequisites>
			<topWindExposure>0.1</topWindExposure>
			<visualSizeRange>1~1</visualSizeRange>
			<wildOrder>2</wildOrder>
			<purpose>Food</purpose>
		</plant>
	</ThingDef>

	<ThingDef ParentName="PlantFoodRawBase">
		<defName>RawGrapes</defName>
		<label>grapes</label>
		<description>Plump grapes cultivated by the Leeani for winemaking. They have a rich, sweet flavor and can be eaten raw or used to brew soul wine.</description>
		<graphicData>
			<texPath>Things/Item/RawFood/RawGrapes</texPath>
		</graphicData>
		<statBases>
			<MarketValue>3.25</MarketValue>
			<FoodPoisonChanceFixedHuman>0.0</FoodPoisonChanceFixedHuman>
		</statBases>
		<ingestible>
			<preferability>RawTasty</preferability>
			<tasteThought/>
			<foodType>VegetableOrFruit</foodType>
		</ingestible>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>20</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
	</ThingDef>

</Defs>