	<!-- Leader -->
	<PawnKindDef ParentName="LeeaniStarwalkerBase">
		<defName>LeeaniStarwalker_Navigator</defName>
		<label>navigator-supreme</label>
		<labelPlural>navigators-supreme</labelPlural>
		<combatPower>120</combatPower>
		<isFighter>true</isFighter>
		<factionLeader>true</factionLeader>
		<gearHealthRange>1.0~3.0</gearHealthRange>
		<itemQuality>Excellent</itemQuality>
		<backstoryCategories>
			<li>Offworld</li>
		</backstoryCategories>
		<minGenerationAge>30</minGenerationAge>
		<maxGenerationAge>65</maxGenerationAge>
		<apparelMoney>3000~6000</apparelMoney>
		<weaponMoney>2500~5000</weaponMoney>
		<weaponTags>
			<li>Gun</li>
			<li>IndustrialGunAdvanced</li>
			<li>SpacerGun</li>
		</weaponTags>
		<techHediffsChance>0.50</techHediffsChance>
		<techHediffsMoney>3000~8000</techHediffsMoney>
		<techHediffsTags>
			<li>Advanced</li>
		</techHediffsTags>
		<inventoryOptions>
			<skipChance>0.6</skipChance>
			<subOptionsChooseOne>
				<li>
					<thingDef>Silver</thingDef>
					<countRange>
						<min>500</min>
						<max>1200</max>
					</countRange>
				</li>
				<li>
					<thingDef>MedicineUltratech</thingDef>
					<countRange>
