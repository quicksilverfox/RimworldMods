<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="ArtableFurnitureBase">
		<defName>LoordThrone</defName>
		<label>Leeani throne</label>
		<thingClass MayRequire="Ludeon.RimWorld.Royalty">Building_Throne</thingClass>
		<graphicData>
			<texPath>Things/Building/Furniture/LoordThrone</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,3)</drawSize>
			<shadowData>
				<volume>(0.3, 0.6, 0.3)</volume>
			</shadowData>
			<damageData>
				<rectN>(0.25,0.234375,0.5,0.28125)</rectN>
				<rectS>(0.25,0.234375,0.5,0.28125)</rectS>
				<rectE>(0.28125,0.25,0.453125,0.25)</rectE>
				<rectW>(0.28125,0.25,0.453125,0.25)</rectW>
			</damageData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<defaultPlacingRot>South</defaultPlacingRot>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>10000</WorkToBuild>
			<Mass>25</Mass>
			<Beauty>20</Beauty>
			<Comfort>1.00</Comfort>
			<MeditationFocusStrength MayRequire="Ludeon.RimWorld.Royalty">0.15</MeditationFocusStrength>
		</statBases>
		<description>An ornate throne fit for a Leeani leader. The elaborate carvings and comfortable seat demonstrate the artistry and traditions of Leeani craftsmanship. Can be used for dignified meditation by psycasters and fulfills throneroom requirements for royalty.</description>
		<socialPropernessMatters>true</socialPropernessMatters>
		<stuffCategories>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>120</costStuffCount>
		<costList>
			<Cloth>80</Cloth>
			<Gold>15</Gold>
		</costList>
		<pathCost>30</pathCost>
		<designationHotKey>Misc7</designationHotKey>
		<fillPercent>0.35</fillPercent>
		<building>
			<isSittable>true</isSittable>
			<paintable>true</paintable>
		</building>
		<comps>
			<li Class="CompProperties_AssignableToPawn" MayRequire="Ludeon.RimWorld.Royalty">
				<drawAssignmentOverlay>true</drawAssignmentOverlay>
				<compClass>CompAssignableToPawn_Throne</compClass>
			</li>
			<li Class="CompProperties_MeditationFocus" MayRequire="Ludeon.RimWorld.Royalty">
				<statDef>MeditationFocusStrength</statDef>
				<focusTypes>
					<li>Dignified</li>
				</focusTypes>
				<offsets>
					<li Class="FocusStrengthOffset_ThroneSatisfiesRequirements">
						<offset>0.08</offset>
					</li>
					<li Class="FocusStrengthOffset_RoomImpressiveness">
						<curve>
							<points>
								<li>(0,   -0.05)</li>
								<li>(30,   0.00)</li>
								<li>(60,   0.04)</li>
								<li>(100,  0.08)</li>
								<li>(170,  0.10)</li>
							</points>
						</curve>
					</li>
				</offsets>
			</li>
		</comps>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<tradeTags>
			<li>LeeaniFurniture</li>
		</tradeTags>
	</ThingDef>

	<ThingDef ParentName="ArtableFurnitureBase">
		<defName>BanquetChair</defName>
		<label>banquet chair</label>
		<graphicData>
			<texPath>Things/Building/Furniture/BanquetChair</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3,3)</drawSize>
			<shadowData>
				<volume>(0.3, 0.3, 0.3)</volume>
			</shadowData>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<defaultPlacingRot>South</defaultPlacingRot>
		<statBases>
			<MaxHitPoints>250</MaxHitPoints>
			<WorkToBuild>1500</WorkToBuild>
			<Mass>10</Mass>
			<Flammability>1.0</Flammability>
			<Beauty>12</Beauty>
			<Comfort>0.75</Comfort>
		</statBases>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>40</costStuffCount>
		<description>An esteemed chair, decorated and made for a noble or court guest!</description>
		<socialPropernessMatters>true</socialPropernessMatters>
		<pathCost>30</pathCost>
		<designationHotKey>Misc7</designationHotKey>
		<fillPercent>0.35</fillPercent>
		<size>(1,1)</size>
		<building>
			<isSittable>true</isSittable>
		</building>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<tradeTags>
			<li>LeeaniFurniture</li>
		</tradeTags>
	</ThingDef>

	<ThingDef Abstract="True" ParentName="ArtableFurnitureBase" Name="LArtTableBase">
		<thingClass>Building</thingClass>
		<altitudeLayer>Building</altitudeLayer>
		<description>People eat off tables when chairs are placed facing them.</description>
		<passability>PassThroughOnly</passability>
		<castEdgeShadows>true</castEdgeShadows>
		<pathCost>60</pathCost>
		<fillPercent>0.4</fillPercent>
		<socialPropernessMatters>true</socialPropernessMatters>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>
		<surfaceType>Eat</surfaceType>
		<comps>
			<li>
				<compClass>CompGatherSpot</compClass>
			</li>
		</comps>
	</ThingDef>

	<ThingDef ParentName="LArtTableBase">
		<defName>BanquetTable</defName>
		<label>banquet table</label>
		<graphicData>
			<texPath>Things/Building/Furniture/BanquetTable</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(3.8,1.8)</drawSize>
			<damageData>
				<rect>(0.05,0.27,1.9,1.73)</rect>
			</damageData>
		</graphicData>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<WorkToBuild>2500</WorkToBuild>
			<Mass>10</Mass>
			<Flammability>0.0</Flammability>
			<Beauty>15</Beauty>
		</statBases>
		<size>(3,1)</size>
		<stuffCategories>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>80</costStuffCount>
		<rotatable>true</rotatable>
		<comps>
			<li>
				<compClass>CompQuality</compClass>
			</li>
			<li Class="CompProperties_Art">
				<nameMaker>NamerArtFurniture</nameMaker>
				<descriptionMaker>ArtDescription_Furniture</descriptionMaker>
				<minQualityForArtistic>Excellent</minQualityForArtistic>
			</li>
		</comps>
		<inspectorTabs>
			<li>ITab_Art</li>
		</inspectorTabs>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<tradeTags>
			<li>LeeaniFurniture</li>
		</tradeTags>
	</ThingDef>

	<ThingDef ParentName="FurnitureBase">
		<defName>LeeaniStoneBrazier</defName>
		<label>brazier</label>
		<description>A bowl-shaped stone furnishing used to hold a fire. Will light the surroundings and create heat. Appropriate for royal thronerooms and can be used for flame-focused meditation.</description>
		<category>Building</category>
		<tickerType>Normal</tickerType>
		<drawerType>RealtimeOnly</drawerType>
		<graphicData>
			<texPath>Things/Building/Furniture/Brazier</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawRotated>false</drawRotated>
			<allowFlip>false</allowFlip>
			<shadowData>
				<volume>(0.55, 0.35, 0.3)</volume>
				<offset>(0, 0, -0.28)</offset>
			</shadowData>
			<damageData>
				<rect>(0.2,0.3,0.6,0.6)</rect>
			</damageData>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<pathCost>42</pathCost>
		<fillPercent>0.15</fillPercent>
		<statBases>
			<MaxHitPoints>80</MaxHitPoints>
			<WorkToBuild>1000</WorkToBuild>
			<Flammability>0</Flammability>
			<Mass>15</Mass>
			<MeditationFocusStrength MayRequire="Ludeon.RimWorld.Royalty">0.0</MeditationFocusStrength>
		</statBases>
		<selectable>true</selectable>
		<designationCategory>Furniture</designationCategory>
		<uiOrder>2820</uiOrder>
		<uiIconOffset>(0, -0.04)</uiIconOffset>
		<minifiedDef>MinifiedThing</minifiedDef>
		<stuffCategories>
			<li>Metallic</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>50</costStuffCount>
		<canOverlapZones>false</canOverlapZones>
		<rotatable>false</rotatable>
		<placeWorkers>
			<li>PlaceWorker_Heater</li>
			<li MayRequire="Ludeon.RimWorld.Royalty">PlaceWorker_MeditationOffsetBuildingsNear</li>
			<li MayRequire="Ludeon.RimWorld.Royalty">PlaceWorker_GlowRadius</li>
		</placeWorkers>
		<drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
		<comps>
			<li Class="CompProperties_Refuelable">
				<fuelConsumptionRate>2.0</fuelConsumptionRate>
				<fuelCapacity>30.0</fuelCapacity>
				<fuelConsumptionPerTickInRain>0.0006</fuelConsumptionPerTickInRain>
				<fuelFilter>
					<thingDefs>
						<li>WoodLog</li>
					</thingDefs>
				</fuelFilter>
				<initialFuelPercent>0</initialFuelPercent>
				<showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
				<functionsInVacuum>false</functionsInVacuum>
			</li>
			<li Class="CompProperties_Glower">
				<glowRadius>10</glowRadius>
				<glowColor>(252,187,113,0)</glowColor>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>CompHeatPusherPowered</compClass>
				<heatPerSecond>3.5</heatPerSecond>
				<heatPushMaxTemperature>23</heatPushMaxTemperature>
			</li>
			<li Class="CompProperties_FireOverlay">
				<fireSize>1</fireSize>
				<offset>(0,0,0.18)</offset>
			</li>
			<li Class="CompProperties_MeditationFocus" MayRequire="Ludeon.RimWorld.Royalty">
				<statDef>MeditationFocusStrength</statDef>
				<focusTypes>
					<li>Flame</li>
				</focusTypes>
				<offsets>
					<li Class="FocusStrengthOffset_Lit">
						<offset>0.15</offset>
					</li>
					<li Class="FocusStrengthOffset_BuildingDefsLit">
						<defs>
							<li>Campfire</li>
							<li>TorchLamp</li>
							<li MayRequire="Ludeon.RimWorld.Royalty">Brazier</li>
							<li>LeeaniStoneBrazier</li>
							<li MayRequire="Ludeon.RimWorld.Royalty,Ludeon.RimWorld.Ideology">DarklightBrazier</li>
							<li MayRequire="Ludeon.RimWorld.Ideology">Darktorch</li>
							<li MayRequire="Ludeon.RimWorld.Ideology">DarktorchFungus</li>
						</defs>
						<offsetPerBuilding>0.02</offsetPerBuilding>
						<radius>9.9</radius>
						<maxBuildings>8</maxBuildings>
						<explanationKey>MeditationFocusPerFlame</explanationKey>
						<explanationKeyAbstract>MeditationFocusPerFlameAbstract</explanationKeyAbstract>
						<drawRingRadius>false</drawRingRadius>
					</li>
				</offsets>
			</li>
		</comps>
		<building>
			<paintable>true</paintable>
		</building>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<tradeTags>
			<li>LeeaniFurniture</li>
		</tradeTags>
	</ThingDef>

	<ThingDef ParentName="ArtableFurnitureBase">
		<defName>LeeaniBookshelf</defName>
		<label>archive</label>
		<description>A reputable repository of rather relatable reading reams. In other words, a bookshelf. Boosts research when placed close to a research bench and can provide some joy to read its contents.</description>
		<graphicData>
			<texPath>Things/Building/Furniture/LeeaniBookshelf</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shadowData>
				<volume>(0.3, 0.6, 0.3)</volume>
			</shadowData>
			<damageData>
				<rect>(0.09375,0.296875,0.796875,0.703125)</rect>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
			<drawSize>(2,2)</drawSize>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<defaultPlacingRot>South</defaultPlacingRot>
		<rotatable>true</rotatable>
		<socialPropernessMatters>true</socialPropernessMatters>
		<fillPercent>0.80</fillPercent>
		<hasInteractionCell>true</hasInteractionCell>
		<interactionCellOffset>(0,0,1)</interactionCellOffset>
		<thingCategories>
			<li>BuildingsJoy</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToBuild>10000</WorkToBuild>
			<Mass>15</Mass>
			<Flammability>1.0</Flammability>
			<Beauty>9</Beauty>
			<JoyGainFactor>1</JoyGainFactor>
		</statBases>
		<stuffCategories>
			<li>Metallic</li>
			<li>Woody</li>
			<li>Stony</li>
		</stuffCategories>
		<costStuffCount>70</costStuffCount>
		<pathCost>70</pathCost>
		<passability>PassThroughOnly</passability>
		<designationCategory>Joy</designationCategory>
		<designationHotKey>Misc2</designationHotKey>
		<comps>
			<li Class="CompProperties_Facility">
				<statOffsets>
					<ResearchSpeedFactor>0.1</ResearchSpeedFactor>
				</statOffsets>
				<maxSimultaneous>2</maxSimultaneous>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>ComplexFurniture</li>
		</researchPrerequisites>
		<tradeTags>
			<li>LeeaniFurniture</li>
		</tradeTags>
	</ThingDef>

</Defs>